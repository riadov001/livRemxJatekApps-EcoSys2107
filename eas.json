{
  "cli": {
    "version": ">= 14.7.1",
    "appVersionSource": "local",
    "appRoot": "artifacts/jatek-mobile"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "channel": "preview",
      "credentialsSource": "remote",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "ma.jatek.app",
        "EXPO_PUBLIC_PROJECT_ID": "2437ecfc-9682-4b07-9eaa-77f6206b4714"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "ma.jatek.app",
        "EXPO_PUBLIC_API_URL": "https://ma.jatek.app",
        "EXPO_PUBLIC_PROJECT_ID": "2437ecfc-9682-4b07-9eaa-77f6206b4714"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
